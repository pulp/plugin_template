#!/bin/bash

{% include 'header.j2' %}

# make sure this script runs at the repo root
cd "$(dirname "$(realpath -e "$0")")"/../..

set -u

MATCHES="$(grep -n -r --include \*.py "_(f" {% for plugin in plugins -%}{{plugin.name | snake }} {% endfor -%})"

if [ $? -ne 1 ]; then
  printf "\nERROR: Detected mix of f-strings and gettext:\n"
  echo "$MATCHES"
  exit 1
fi
